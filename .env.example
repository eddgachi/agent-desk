# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://office:officepass@office-db:5432/office_sim

# ── Redis / Celery ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Frontend (browser-facing — must use localhost) ────────
# These are read by Vite at build time. The browser reaches the backend
# directly on the host port, not via Docker internal hostnames.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ── LLM (Phase 8) ─────────────────────────────────────────
DEEPSEEK_API_KEY=your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_ENABLED=false

# ── Simulation defaults ───────────────────────────────────
DEFAULT_TICK_INTERVAL=1.0
DEFAULT_SEED=42
